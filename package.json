{
  "name": "baul-digital",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull",
    "db:migrate": "node scripts/migrate.js migrate",
    "db:reset": "node scripts/migrate.js reset",
    "db:seed": "node scripts/migrate.js seed",
    "db:fresh": "node scripts/migrate.js fresh",
    "db:test": "node scripts/db-test.js",
    "setup": "npm install && npm run docker:up && timeout /t 5 /nobreak > nul && npm run db:fresh && npm run db:test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.5",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@supabase/auth-helpers-nextjs": "^0.8.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.38.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "axios": "^1.6.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "next": "^14.1.0",
    "next-pwa": "^5.6.0",
    "pg": "^8.11.0",
    "radix-ui": "^0.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.54.0",
    "pg": "^8.11.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
